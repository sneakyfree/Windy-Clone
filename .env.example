# === Auth ===
WINDY_PRO_JWKS_URL=https://windypro.thewindstorm.uk/.well-known/jwks.json
WINDY_PRO_API_URL=https://api.windypro.com
DEV_MODE=true  # Set to false in production; enables mock user when no JWT is provided
WINDY_PRO_WEBHOOK_SECRET=  # HMAC-SHA256 secret for /api/v1/webhooks/identity/created

# === Dashboard ===
DASHBOARD_URL=https://windyclone.com  # Base URL the identity webhook points new users at

# === Eternitas (live Trust API + auto-hatch + trust.changed webhooks) ===
ETERNITAS_URL=http://localhost:8500
ETERNITAS_API_KEY=
ETERNITAS_USE_MOCK=false  # true → skip HTTP, treat every agent as TOP_SECRET
ETERNITAS_WEBHOOK_SECRET=  # HMAC-SHA256 secret for trust.changed deliveries
ETERNITAS_TRUST_CACHE_TTL=300

# === Soul file export ===
SOUL_SIGNING_KEY_PATH=./data/soul_signing_key.pem
WINDY_SERVICE_TOKEN=  # Cross-service bearer for /clones/{id}/export-soul-file

# === Provider API Keys ===
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
PLAYHT_API_KEY=
PLAYHT_USER_ID=
RESEMBLEAI_API_KEY=

# === Database (defaults to SQLite for dev) ===
DATABASE_URL=sqlite+aiosqlite:///data/windy_clone.db

# === Server ===
HOST=0.0.0.0
PORT=8400
LOG_LEVEL=info
CORS_ORIGINS=https://windyclone.com,http://localhost:5173  # comma-separated; prod default is prod-origin only

# === Affiliate Tracking ===
ELEVENLABS_AFFILIATE_ID=windy
HEYGEN_AFFILIATE_ID=windy
