# ==============================================================================
#  Windy Clone — PRODUCTION env template
# ==============================================================================
#
# Copy to `.env` on the target and fill in every value marked `<REQUIRED>`.
# The boot guards in api/app/main.py:_enforce_boot_guards will refuse to
# start if DEV_MODE, ENVIRONMENT, or any critical URL still looks like a
# placeholder.
#
# Secrets (keys, API tokens) belong in AWS Secrets Manager or the VPS
# host's secrets store, not in this file checked into a repo. This file
# is the *shape*; the runtime values come from the secrets loader.
#
# See DEPLOY.md for the full runbook.
# ------------------------------------------------------------------------------

# ── Environment ──
# Must be "production" in prod. "development" triggers the JWT dev-user
# fallback, which silently accepts any Bearer token as the mock user.
ENVIRONMENT=production
DEV_MODE=false

# ── Auth — Windy Pro JWKS ──
# Clone validates every inbound JWT against Pro's public keys. Swap these
# to the real prod Pro URLs; the *.thewindstorm.uk defaults are placeholder
# hosts and the boot guard will reject them.
WINDY_PRO_JWKS_URL=https://<REQUIRED: prod Pro jwks host>/.well-known/jwks.json
WINDY_PRO_API_URL=https://<REQUIRED: prod Pro api host>
# Shared secret for POST /api/v1/webhooks/identity/created. 32+ random bytes,
# base64 or hex, matches the value in Pro's account-server env.
WINDY_PRO_WEBHOOK_SECRET=<REQUIRED>

# Optional audience / issuer enforcement. Leave JWT_AUDIENCE blank until
# Pro mints audience-scoped tokens; setting it too early 401s everyone.
JWT_AUDIENCE=
JWT_ISSUER=

# ── Dashboard ──
# Clone-hosted frontend origin — used in the identity-created webhook
# redirect and a couple of email templates.
DASHBOARD_URL=https://windyclone.com

# ── Eternitas — auto-hatch + trust ──
# Clone POSTs /api/v1/bots/auto-hatch on every completed clone. Mock is
# explicitly false in prod (treating every agent as TOP_SECRET is the
# opposite of what you want).
ETERNITAS_URL=https://<REQUIRED: prod eternitas host>
ETERNITAS_API_KEY=<REQUIRED>
ETERNITAS_USE_MOCK=false
ETERNITAS_WEBHOOK_SECRET=<REQUIRED>
ETERNITAS_TRUST_CACHE_TTL=300

# Webhook replay defence. Once Eternitas is on the `{ts}.{body}` HMAC
# contract, flip this to true to reject body-only signatures.
WEBHOOK_REQUIRE_TIMESTAMP=false
WEBHOOK_MAX_TIMESTAMP_AGE_SECONDS=300

# ── Soul file export ──
# PEM-encoded ES256 private key. REQUIRED in prod — do not let the service
# auto-generate; each ECS task would mint its own keypair and half the
# soul-file signatures would fail to verify against /.well-known.
SOUL_SIGNING_KEY_PEM=<REQUIRED: load from AWS Secrets Manager, not this file>
# Cross-service bearer for /clones/{id}/export-soul-file. Only sibling
# Windy services carry this header.
WINDY_SERVICE_TOKEN=<REQUIRED>

# ── Provider API keys ──
# Missing key → that provider's adapter returns 501 rather than accepting
# orders and stalling. Enable only the providers you've contracted with.
ELEVENLABS_API_KEY=<REQUIRED if ElevenLabs enabled>
HEYGEN_API_KEY=<REQUIRED if HeyGen enabled>
PLAYHT_API_KEY=<REQUIRED if PlayHT enabled>
PLAYHT_USER_ID=<REQUIRED if PlayHT enabled>
RESEMBLEAI_API_KEY=<REQUIRED if Resemble AI enabled>

# ── Affiliate tracking ──
# Carried on every provider order URL. Override only if you're running a
# separate affiliate program.
ELEVENLABS_AFFILIATE_ID=windy
HEYGEN_AFFILIATE_ID=windy

# ── Database ──
# Prod points at managed Postgres. Do NOT run the default SQLite in prod —
# the per-task SQLite will silently diverge between tasks, and the default
# path (./data/...) isn't persistent on Fargate.
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<rds-host>:5432/windy_clone

# ── (Optional) Cloudflare R2 for soul-file cold storage ──
# Only needed if you're archiving exported soul files off-box. See
# DEPLOY.md §2.1. Omit entirely for the minimum viable deploy.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# ── Server ──
HOST=0.0.0.0
PORT=8400
LOG_LEVEL=info
# Comma-separated list. Prod origins only — no http://localhost.
CORS_ORIGINS=https://windyclone.com,https://www.windyclone.com
# Body cap, applied before body read. Orders/preferences fit well under
# 4 KB; 64 KB leaves headroom without letting abuse 10 MB payloads through.
MAX_REQUEST_BODY_BYTES=65536
